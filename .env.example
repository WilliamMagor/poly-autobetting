# Credentials
POLYMARKET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
POLYMARKET_FUNDER=0xYOUR_FUNDER_ADDRESS_HERE

# Builder Relayer (gasless on-chain transactions)
POLYMARKET_BUILDER_API_KEY=YOUR_BUILDER_API_KEY
POLYMARKET_BUILDER_SECRET=YOUR_BUILDER_SECRET
POLYMARKET_BUILDER_PASSPHRASE=YOUR_BUILDER_PASSPHRASE

# --- 15-minute market config (PLACE_15_ prefix; falls back to PLACE_45_ for compat) ---
# PLACE_15_ENTRY_PRICE=0.46         # Entry price per side (default 0.46)
# PLACE_15_SHARES=10                # Shares per side
# PLACE_15_ENTRY_PRICE_DYNAMIC=0    # 1 = adapt entry to volatility
# PLACE_15_PLACE_WINDOW_S=30        # Placement window (seconds after market start)
# PLACE_15_HEDGE_START_S=240        # Start trailing hedge (4 min; fills tracked from t=0)
# PLACE_15_HEDGE_MID_S=600          # Widen hedge band (10 min)
# PLACE_15_HEDGE_LATE_S=720         # Force-buy / emergency zone (12 min)
# PLACE_15_HEDGE_TRAILING_DELTA=0.03
# PLACE_15_HEDGE_FORCE_THRESHOLD=0.85
# PLACE_15_HEDGE_MAX_COMBINED=0.98  # EV cap: never hedge if entry+hedge > this
# PLACE_15_STALE_CANCEL_S=660       # Cancel unfilled orders at 11 min
# PLACE_15_MAX_OPEN_MARKETS=0       # 0 = no cap
# PLACE_15_REST_FALLBACK=0          # 1 = use REST orderbook when WS unavailable
# PLACE_15_INTEGRITY_INTERVAL_S=3
# PLACE_15_HEARTBEAT_INTERVAL_S=5
# PLACE_15_FRESH_START=0            # 1 = clear all caches + skip startup scan on boot
#                                   #   Use on new VPS / after long gap to avoid stale state
